
def get_next_monday(today=None):
    today = pd.Timestamp(today or datetime.today().date())
    days_ahead = (0 - today.weekday()) % 7   # Monday = 0
    if days_ahead == 0:
        days_ahead = 7                        # if today IS Monday, jump to next week's
    return today + pd.Timedelta(days=days_ahead)
 
forecast_start = get_next_monday()   # uses actual system date; pass a date to override for testing
print(f"Today: {pd.Timestamp(datetime.today().date()).date()}")
print(f"Forecast starts: {forecast_start.date()}")
 
