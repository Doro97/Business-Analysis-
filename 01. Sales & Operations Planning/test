import pandas as pd
import numpy as np
from sklearn.metrics import mean_absolute_error, mean_squared_error

# =============================================================
# 1. SEGMENT BREAKDOWN + ENRICHMENT
# =============================================================
sr_tech = (
    time_card[time_card['task'].isin(sr['number'])]
    .groupby(['task', 'technology', 'specialisation'])['time_worked']
    .sum()
    .reset_index()
    .sort_values('time_worked', ascending=False)
    .drop_duplicates(subset='task', keep='first')
    .rename(columns={'task': 'number'})
)[['number', 'technology', 'specialisation']]

sr_enriched = sr.merge(sr_tech, on='number', how='left')
sr_enriched['week_start'] = pd.to_datetime(sr_enriched['created']).dt.to_period('W').dt.start_time

# =============================================================
# 2. WEEKLY AGGREGATION + CONTEXT MERGE + ENCODING
# =============================================================
weekly_sr_seg = (
    sr_enriched[sr_enriched['technology'].notna()]
    .groupby(['week_start', 'technology', 'specialisation'])
    .size()
    .reset_index(name='sr_count')
    .sort_values(['technology', 'specialisation', 'week_start'])
    .reset_index(drop=True)
)

# weekly_sr_context merge removed — n_companies, n_services, n_request_items,
# n_high_priority, n_assignment_grp are exogenous and can't be forecast forward,
# so they're excluded from the model entirely.

sr_seg_encoded = pd.get_dummies(
    weekly_sr_seg, columns=['technology', 'specialisation'], drop_first=False
)

seg_cols_sr = [
    c for c in sr_seg_encoded.columns
    if c.startswith('technology_') or c.startswith('specialisation_')
]

# =============================================================
# 3. FEATURE ENGINEERING PER SEGMENT (lag_1 + month only, per your code)
# =============================================================
def build_sr_seg_features(df, target_col='sr_count'):
    df = df.copy().sort_values('week_start').reset_index(drop=True)
    df['lag_1'] = df[target_col].shift(1)
    df['month'] = pd.to_datetime(df['week_start']).dt.month
    return df.dropna()

seg_dfs_sr = []
for _, grp in sr_seg_encoded.groupby(seg_cols_sr, as_index=False):
    featured = build_sr_seg_features(grp)
    if len(featured) > 5:
        seg_dfs_sr.append(featured)

all_seg_sr = pd.concat(seg_dfs_sr).reset_index(drop=True)

# =============================================================
# 4. TRAIN/TEST SPLIT + MODEL SELECTION
# =============================================================
FEATURES_SR_SEG = [c for c in all_seg_sr.columns if c not in ['sr_count', 'week_start']]
X_seg_sr = all_seg_sr[FEATURES_SR_SEG]
y_seg_sr = all_seg_sr['sr_count']

cutoff_sr_seg = all_seg_sr['week_start'].max() - pd.Timedelta(weeks=13)
train_m_sr = all_seg_sr['week_start'] <= cutoff_sr_seg
test_m_sr = all_seg_sr['week_start'] > cutoff_sr_seg

X_train_seg_sr, X_test_seg_sr = X_seg_sr[train_m_sr], X_seg_sr[test_m_sr]
y_train_seg_sr, y_test_seg_sr = y_seg_sr[train_m_sr], y_seg_sr[test_m_sr]

results_seg_sr = []
fitted_seg_sr = {}
for name, model in models.items():
    model.fit(X_train_seg_sr, y_train_seg_sr)
    fitted_seg_sr[name] = model
    preds = np.asarray(np.maximum(model.predict(X_test_seg_sr), 0).round()).ravel()
    results_seg_sr.append({
        'Model': name,
        'MAE': round(mean_absolute_error(y_test_seg_sr, preds), 1),
        'RMSE': round(np.sqrt(mean_squared_error(y_test_seg_sr, preds)), 1),
        'Bias': round(np.mean(preds - y_test_seg_sr.values), 1),
    })

print(pd.DataFrame(results_seg_sr).sort_values('MAE'))

# =============================================================
# 5. FIT BEST MODEL (Lasso, per your backtest) ON ALL DATA
# =============================================================
best_sr_seg = fitted_seg_sr['Lasso']
best_sr_seg.fit(X_seg_sr, y_seg_sr)  # refit on full history before forecasting forward

tech_cols_sr = [c for c in all_seg_sr.columns if c.startswith('technology_')]
spec_cols_sr = [c for c in all_seg_sr.columns if c.startswith('specialisation_')]

# =============================================================
# 6. BACKTEST SANITY CHECK (optional, matches your screenshots)
# =============================================================
test_seg_sr = all_seg_sr[test_m_sr].copy()
test_seg_sr['predicted'] = np.asarray(
    np.maximum(fitted_seg_sr['Lasso'].predict(X_test_seg_sr), 0).round()
).ravel()

test_seg_sr['technology'] = (
    test_seg_sr[tech_cols_sr].idxmax(axis=1).str.replace('technology_', '', regex=False)
)
test_seg_sr['specialisation'] = (
    test_seg_sr[spec_cols_sr].idxmax(axis=1).str.replace('specialisation_', '', regex=False)
)

segment_metrics_sr = (
    test_seg_sr.groupby(['technology', 'specialisation'])[['sr_count', 'predicted']]
    .apply(lambda g: pd.Series({'MAE': mean_absolute_error(g['sr_count'], g['predicted'])}))
    .reset_index()
    .sort_values('MAE', ascending=False)
)
segment_metrics_sr['MAE'] = segment_metrics_sr['MAE'].round(2)
segment_metrics_sr = segment_metrics_sr.reset_index(drop=True)
print(segment_metrics_sr)

# =============================================================
# 7. 13-WEEK FORWARD FORECAST (recursive, anchored to next week from today)
# =============================================================
N_WEEKS_AHEAD = 13
TARGET_COL = 'sr_count'
today = pd.Timestamp.today().normalize()

this_week_start = today.to_period('W').start_time
next_week_start = this_week_start + pd.Timedelta(weeks=1)

forecast_rows_sr = []

for seg_key, grp in sr_seg_encoded.groupby(seg_cols_sr, as_index=False):
    grp = grp.sort_values('week_start').reset_index(drop=True)
    if len(grp) < 5:
        continue

    seg_dummy_values = grp.iloc[-1][seg_cols_sr]
    history = grp[['week_start', TARGET_COL]].copy()
    preds_this_seg = []

    last_output_date = next_week_start + pd.Timedelta(weeks=N_WEEKS_AHEAD - 1)

    while True:
        last_date = history['week_start'].max()
        next_date = last_date + pd.Timedelta(weeks=1)
        if next_date > last_output_date:
            break

        lag_1 = history[TARGET_COL].iloc[-1]
        month = next_date.month

        feat_row = {'lag_1': lag_1, 'month': month}
        for c in seg_cols_sr:
            feat_row[c] = seg_dummy_values[c]

        X_next = pd.DataFrame([feat_row])[FEATURES_SR_SEG]
        if X_next.shape[0] != 1:
            raise ValueError(f"X_next has {X_next.shape[0]} rows, expected 1")

        raw_pred = np.asarray(best_sr_seg.predict(X_next)).ravel()
        pred = float(np.maximum(raw_pred[0], 0).round())

        history = pd.concat(
            [history, pd.DataFrame({'week_start': [next_date], TARGET_COL: [pred]})],
            ignore_index=True,
        )

        if next_date >= next_week_start:
            preds_this_seg.append((next_date, pred))

    technology = None
    specialisation = None
    for c in tech_cols_sr:
        if seg_dummy_values[c] == 1:
            technology = c.replace('technology_', '')
    for c in spec_cols_sr:
        if seg_dummy_values[c] == 1:
            specialisation = c.replace('specialisation_', '')

    row = {'technology': technology, 'specialisation': specialisation}
    for date, pred in preds_this_seg:
        row[date.strftime('%Y-%m-%d')] = pred
    row['pxn_date'] = today.date()
    forecast_rows_sr.append(row)

forecast_df_sr = pd.DataFrame(forecast_rows_sr)
week_cols_sr = sorted(
    [c for c in forecast_df_sr.columns if c not in ('technology', 'specialisation', 'pxn_date')]
)
forecast_df_sr = forecast_df_sr[['technology', 'specialisation'] + week_cols_sr + ['pxn_date']]

output_filename_sr = f"sr_forecast_13week_{today.strftime('%Y-%m-%d')}.csv"
forecast_df_sr.to_csv(output_filename_sr, index=False)
print(f"Saved: {output_filename_sr}")
print(forecast_df_sr)
