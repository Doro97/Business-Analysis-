for seg_key, grp in cr_seg_encoded.groupby(seg_cols_cr, as_index=False):
    grp = grp.sort_values('week_start').reset_index(drop=True)
    if len(grp) < 5:
        continue  # not enough history for lag/rolling features
 
    seg_dummy_values = grp.iloc[-1][seg_cols_cr]
    history = grp[['week_start', TARGET_COL]].copy()
    preds_this_seg = []
 
    for step in range(1, N_WEEKS_AHEAD + 1):
        last_date = history['week_start'].max()
        next_date = last_date + pd.Timedelta(weeks=1)
 
        lag_1 = history[TARGET_COL].iloc[-1]
        roll_4w = history[TARGET_COL].iloc[-4:].mean()
        prev_roll_4w = (
            history[TARGET_COL].iloc[-5:-1].mean()
            if len(history) >= 5
            else history[TARGET_COL].iloc[:-1].mean()
        )
        shift_2 = history[TARGET_COL].iloc[-2] if len(history) >= 2 else lag_1
        momentum = roll_4w - shift_2
        month = next_date.month
 
        feat_row = {'lag_1': lag_1, 'roll_4w': roll_4w, 'momentum': momentum, 'month': month}
        for c in seg_cols_cr:
            feat_row[c] = seg_dummy_values[c]
 
        X_next = pd.DataFrame([feat_row])[FEATURES_CR_SEG]
        if X_next.shape[0] != 1:
            raise ValueError(f"X_next has {X_next.shape[0]} rows, expected 1")
 
        raw_pred = np.asarray(best_cr_seg.predict(X_next)).ravel()
        pred = float(np.maximum(raw_pred[0], 0).round())
 
        preds_this_seg.append((next_date, pred))
        history = pd.concat(
            [history, pd.DataFrame({'week_start': [next_date], TARGET_COL: [pred]})],
            ignore_index=True,
        )
 
    technology = None
    specialisation = None
    for c in tech_cols_cr:
        if seg_dummy_values[c] == 1:
            technology = c.replace('technology_', '')
    for c in spec_cols_cr:
        if seg_dummy_values[c] == 1:
            specialisation = c.replace('specialisation_', '')
 
    row = {'technology': technology, 'specialisation': specialisation}
    for i, (_, pred) in enumerate(preds_this_seg, start=1):
        row[f'week_{i}'] = pred
    row['pxn_date'] = today.date()
    forecast_rows.append(row)
 
forecast_df = pd.DataFrame(forecast_rows)
week_cols = [f'week_{i}' for i in range(1, N_WEEKS_AHEAD + 1)]
