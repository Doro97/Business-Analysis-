def recursive_forecast(model, history, n_steps, feature_cols):
    """Forecast n_steps ahead, feeding predictions back in as lags."""
    history = list(history)  # actual + predicted values as we go
    preds = []
    for step in range(n_steps):
        lag_1 = history[-1]
        lag_2 = history[-2]
        lag_3 = history[-3]
        rolling_mean_4 = np.mean(history[-4:])
        trend_idx = len(history)  # continues the trend index from training
        X_next = pd.DataFrame([{
            "lag_1": lag_1, "lag_2": lag_2, "lag_3": lag_3,
            "rolling_mean_4": rolling_mean_4, "trend_idx": trend_idx
        }])[feature_cols]
        pred = model.predict(X_next)[0]
        preds.append(pred)
        history.append(pred)  # feed prediction back in for next step
    return np.array(preds)

feature_cols = ["lag_1", "lag_2", "lag_3", "rolling_mean_4", "trend_idx"]

