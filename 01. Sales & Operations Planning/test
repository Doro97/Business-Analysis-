import numpy as np
import pandas as pd
from sklearn.linear_model import Ridge, Lasso
from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import mean_absolute_error
import matplotlib.pyplot as plt

# ------------------------------------------------------------------
# 0. Starting point: ts_cleaned (from Step 4)
# ------------------------------------------------------------------
def mape(actual, pred):
    return np.mean(np.abs((actual - pred) / actual)) * 100

MAX_HORIZON = 13
HOLDOUT_WEEKS = 6   # weeks used to validate, held out from training entirely

# ------------------------------------------------------------------
# 1. Base feature set (self-features only for now — timecard features
#    to be added later). Built once; reused per horizon.
# ------------------------------------------------------------------
def build_base_features(ts):
    df = pd.DataFrame({"y": ts})
    df["lag_1"] = df["y"].shift(1)
    df["lag_2"] = df["y"].shift(2)
    df["lag_3"] = df["y"].shift(3)
    df["lag_4"] = df["y"].shift(4)
    df["rolling_mean_4"] = df["y"].shift(1).rolling(4).mean()
    df["rolling_std_4"] = df["y"].shift(1).rolling(4).std()
    df["trend_idx"] = np.arange(len(df))
    return df

