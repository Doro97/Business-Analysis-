# 1. Cap the anomalous weeks using surrounding rolling median
anomaly_mask = (ts.index >= "2026-04-20") & (ts.index <= "2026-05-18")

rolling_median = ts.rolling(8, center=True, min_periods=4).median()
ts_cleaned = ts.copy()
ts_cleaned[anomaly_mask] = rolling_median[anomaly_mask]

print(pd.DataFrame({"raw": ts[anomaly_mask], "cleaned": ts_cleaned[anomaly_mask]}))

# 2. Re-split train/test on the CLEANED series (same holdout window as before)
train_c = ts_cleaned.iloc[:-holdout_n]
test_c = ts_cleaned.iloc[-holdout_n:]   # note: test set is also cleaned now,
                                         # so we're validating against a fair baseline

# 3. Re-fit Holt's damped trend on cleaned data
model_trend_c = ExponentialSmoothing(
    train_c, trend="add", damped_trend=True, seasonal=None
).fit()
pred_trend_c = model_trend_c.forecast(holdout_n)

mae_trend_c = mean_absolute_error(test_c.values, pred_trend_c.values)
mape_trend_c = mape(test_c.values, pred_trend_c.values)

print(f"Cleaned Holt's -> MAPE: {mape_trend_c:.1f}%  MAE: {mae_trend_c:.1f} tickets")
print(pd.DataFrame({"actual": test_c, "forecast": pred_trend_c}))








fig, axes = plt.subplots(2, 1, figsize=(12, 10))

# Top: raw vs cleaned, full history
axes[0].plot(ts.index, ts.values, color="lightcoral", label="Raw (with spike)", linewidth=1)
axes[0].plot(ts_cleaned.index, ts_cleaned.values, color="black", label="Cleaned", linewidth=1.5)
axes[0].axvspan(ts.index[anomaly_mask][0], ts.index[anomaly_mask][-1],
                color="yellow", alpha=0.2, label="Capped window")
