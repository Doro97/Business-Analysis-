# ------------------------------------------------------------------
# 1. Actual totals (up to last actual week, July 6)
# ------------------------------------------------------------------
actual_totals = (
    weekly_total[weekly_total['week_start'] <= '2026-07-06']
    [['week_start', 'ticket_count']]
    .rename(columns={'ticket_count': 'actual'})
    .copy()
)
actual_totals['week_start'] = pd.to_datetime(actual_totals['week_start'])

# ------------------------------------------------------------------
# 2. Predicted totals — sum forecast_df_inc across all technologies,
#    per week column
# ------------------------------------------------------------------
week_cols = [c for c in forecast_df_inc.columns if c not in ('technology', 'pxn_date')]

predicted_totals = (
    forecast_df_inc[week_cols]
    .sum(axis=0)
    .reset_index()
)
predicted_totals.columns = ['week_start', 'predicted']
predicted_totals['week_start'] = pd.to_datetime(predicted_totals['week_start'])

# ------------------------------------------------------------------
# 3. Combine into one dataframe: week_start, actual, predicted
# ------------------------------------------------------------------
total_actual_vs_predicted = pd.merge(
    actual_totals, predicted_totals,
    on='week_start', how='outer'
).sort_values('week_start').reset_index(drop=True)

print(total_actual_vs_predicted.to_string(index=False))
