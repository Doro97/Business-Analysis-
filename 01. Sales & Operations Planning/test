anomaly_mask = (ts.index >= "2026-04-20") & (ts.index <= "2026-05-18")
rolling_median = ts.rolling(8, center=True, min_periods=4).median()
ts_cleaned = ts.astype(float).copy()
ts_cleaned[anomaly_mask] = rolling_median[anomaly_mask]

def mape(actual, pred):
    return np.mean(np.abs((actual - pred) / actual)) * 100

MAX_HORIZON = 13
HOLDOUT_WEEKS = 6

# ------------------------------------------------------------------
# 1. Base feature set (self-features only for now)
# ------------------------------------------------------------------
def build_base_features(ts):
    df = pd.DataFrame({"y": ts})
    df["lag_1"] = df["y"].shift(1)
    df["lag_2"] = df["y"].shift(2)
    df["lag_3"] = df["y"].shift(3)
    df["lag_4"] = df["y"].shift(4)
    df["rolling_mean_4"] = df["y"].shift(1).rolling(4).mean()
    df["rolling_std_4"] = df["y"].shift(1).rolling(4).std()
    df["trend_idx"] = np.arange(len(df))
    return df

base_df = build_base_features(ts_cleaned)

# ------------------------------------------------------------------
# 2. Direct multi-horizon dataset builder
#    target(h) = value h weeks after the feature row's date
# ------------------------------------------------------------------
def build_horizon_dataset(base_df, horizon):
    d = base_df.copy()
    d["target"] = d["y"].shift(-horizon)
    d = d.dropna()
    feature_cols = [c for c in d.columns if c not in ("y", "target")]
    return d[feature_cols], d["target"], feature_cols

# ------------------------------------------------------------------
# 3. Candidate models
# ------------------------------------------------------------------
def get_models():
    return {
        "Ridge": Pipeline([("scaler", StandardScaler()), ("model", Ridge(alpha=1.0))]),
        "Lasso": Pipeline([("scaler", StandardScaler()), ("model", Lasso(alpha=1.0))]),
        "RandomForest": RandomForestRegressor(n_estimators=200, max_depth=4, random_state=42),
        "GradientBoosting": GradientBoostingRegressor(n_estimators=100, learning_rate=0.05, max_depth=3, random_state=42),
    }

# ------------------------------------------------------------------
# 4. Evaluate each model at EACH horizon (1..13), fair holdout
# ------------------------------------------------------------------
results = []
predictions = {name: [] for name in get_models()}
actuals_by_horizon = []

for h in range(1, MAX_HORIZON + 1):
    X_h, y_h, feature_cols = build_horizon_dataset(base_df, h)

    X_train, y_train = X_h.iloc[:-HOLDOUT_WEEKS], y_h.iloc[:-HOLDOUT_WEEKS]
    X_test, y_test = X_h.iloc[-HOLDOUT_WEEKS:], y_h.iloc[-HOLDOUT_WEEKS:]

    if len(X_test) == 0:
        continue

    actuals_by_horizon.append(y_test.values[-1])

    for name, model in get_models().items():
        model.fit(X_train, y_train)
        pred = model.predict(X_test.iloc[[-1]])[0]
        predictions[name].append(pred)

# ------------------------------------------------------------------
# 5. Score each model across all horizons against actuals
# ------------------------------------------------------------------
actuals_arr = np.array(actuals_by_horizon)
for name, preds in predictions.items():
    preds_arr = np.array(preds)
    mae = mean_absolute_error(actuals_arr, preds_arr)
    mp = mape(actuals_arr, preds_arr)
    results.append({"model": name, "MAE": round(mae, 1), "MAPE": round(mp, 1)})

results_df = pd.DataFrame(results).sort_values("MAE")
print(results_df)
print(f"\nHolt's benchmark -> MAE: 10.1  MAPE: 12.1%")
