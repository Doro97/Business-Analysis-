# ------------------------------------------------------------------
# 1. Actual, per technology — up to July 6
# ------------------------------------------------------------------
actual_by_tech = (
    inc_by_tech[inc_by_tech['week_start'] <= '2026-07-06']
    [['week_start', 'technology', 'ticket_count']]
    .rename(columns={'ticket_count': 'actual'})
    .copy()
)
actual_by_tech['week_start'] = pd.to_datetime(actual_by_tech['week_start'])

# ------------------------------------------------------------------
# 2. Predicted, per technology — melt forecast_df_inc from wide to long
# ------------------------------------------------------------------
week_cols = [c for c in forecast_df_inc.columns if c not in ('technology', 'pxn_date')]

predicted_by_tech = forecast_df_inc.melt(
    id_vars='technology',
    value_vars=week_cols,
    var_name='week_start',
    value_name='predicted'
)
predicted_by_tech['week_start'] = pd.to_datetime(predicted_by_tech['week_start'])

# ------------------------------------------------------------------
# 3. Combine: one row per (week_start, technology), actual + predicted
# ------------------------------------------------------------------
by_tech_actual_vs_predicted = pd.merge(
    actual_by_tech, predicted_by_tech,
    on=['week_start', 'technology'], how='outer'
).sort_values(['technology', 'week_start']).reset_index(drop=True)

print(by_tech_actual_vs_predicted.to_string(index=False))
