segments_present = list(segment_best_models_sr.keys())
n_sr = len(segments_present)

fig, axes = plt.subplots(n_sr + 1, 1, figsize=(14, 4 * (n_sr + 1)))

# Total panel
best_sr_total = fitted_sr['Huber']
