import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from statsmodels.tsa.holtwinters import ExponentialSmoothing
from sklearn.metrics import mean_absolute_error

# ------------------------------------------------------------------
# 1. Rebuild cleaned weekly series (from weekly_total, Step 3)
# ------------------------------------------------------------------
ts = weekly_total.set_index("week_start")["ticket_count"].asfreq("W-MON")

anomaly_mask = (ts.index >= "2026-04-20") & (ts.index <= "2026-05-18")
rolling_median = ts.rolling(8, center=True, min_periods=4).median()
ts_cleaned = ts.copy()
ts_cleaned[anomaly_mask] = rolling_median[anomaly_mask]

def mape(actual, pred):
    return np.mean(np.abs((actual - pred) / actual)) * 100

# ------------------------------------------------------------------
# 2. Holdout validation (6 weeks)
# ------------------------------------------------------------------
holdout_n = 6
train_c = ts_cleaned.iloc[:-holdout_n]
test_c = ts_cleaned.iloc[-holdout_n:]

model_trend_c = ExponentialSmoothing(
    train_c, trend="add", damped_trend=True, seasonal=None
).fit()
pred_trend_c = model_trend_c.forecast(holdout_n)

mae_trend_c = mean_absolute_error(test_c.values, pred_trend_c.values)
mape_trend_c = mape(test_c.values, pred_trend_c.values)
print(f"Holdout validation -> MAE: {mae_trend_c:.1f}  MAPE: {mape_trend_c:.1f}%")
print(pd.DataFrame({"actual": test_c, "forecast": pred_trend_c}))

# ------------------------------------------------------------------
# 3. Refit on FULL cleaned series, generate final 13-week forecast
# ------------------------------------------------------------------
final_model = ExponentialSmoothing(
    ts_cleaned, trend="add", damped_trend=True, seasonal=None
).fit()

forecast_13wk = final_model.forecast(13)

resid_std = final_model.resid.std()
forecast_df = pd.DataFrame({
    "week_start": forecast_13wk.index,
    "forecast": forecast_13wk.values,
    "lower_80": (forecast_13wk.values - 1.28 * resid_std).clip(min=0),
    "upper_80": forecast_13wk.values + 1.28 * resid_std,
})
print(forecast_df)

# ------------------------------------------------------------------
# 4. Plot: history + forecast with confidence band
# ------------------------------------------------------------------
fig, ax = plt.subplots(figsize=(13, 6))
ax.plot(ts_cleaned.index, ts_cleaned.values, color="black", label="History (cleaned)")
ax.plot(forecast_df["week_start"], forecast_df["forecast"], color="tab:blue",
        marker="o", label="13-week forecast")
ax.fill_between(forecast_df["week_start"], forecast_df["lower_80"], forecast_df["upper_80"],
                color="tab:blue", alpha=0.15, label="80% interval")
ax.axvline(ts_cleaned.index[-1], color="red", linestyle=":", alpha=0.6)
ax.set_title("Weekly Incident Volume: History + 13-Week Forecast (Holt's Damped Trend)")
ax.set_xlabel("Week")
ax.set_ylabel("Ticket Count")
ax.legend()
ax.grid(alpha=0.3)
plt.xticks(rotation=45)
plt.tight_layout()
plt.savefig("final_13wk_forecast.png", dpi=150)
plt.show()
