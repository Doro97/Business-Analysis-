for (tech, spec), seg_info in segment_best_models_sr.items():
    try:
        explainer = shap.Explainer(
            seg_info['model'].predict,
            seg_info['X_train'].values,  # pass as numpy array
            algorithm='permutation'
        )
        shap_values = explainer(seg_info['X_test'].values)

        fig, axes = plt.subplots(1, 2, figsize=(16, 4))

        plt.sca(axes[0])
        shap.summary_plot(shap_values, seg_info['X_test'],
                          plot_type='bar', show=False)
        axes[0].set_title(f'{tech} | {spec} — Feature Importance')

        plt.sca(axes[1])
        shap.summary_plot(shap_values, seg_info['X_test'], show=False)
        axes[1].set_title(f'{tech} | {spec} — Beeswarm')

        plt.suptitle(
            f'SHAP — {tech} | {spec} (Best: {seg_info["model_name"]}, MAE: {seg_info["MAE"]})',
            fontsize=12, fontweight='bold'
        )
        plt.tight_layout()
        plt.show()

    except Exception as e:
        print(f"SHAP failed for {tech} | {spec}: {e}")
