
N_WEEKS_AHEAD = 13
TARGET_COL = 'ticket_count'
today = pd.Timestamp.today().normalize()
 
this_week_start = today.to_period('W').start_time
next_week_start = this_week_start + pd.Timedelta(weeks=1)
last_output_date = next_week_start + pd.Timedelta(weeks=N_WEEKS_AHEAD - 1)
 
forecast_rows_ticket = []
 
for tech, info in segment_best_models.items():
    model = info['model']
    grp = weekly_segments[
        weekly_segments[[c for c in tech_map_cols if c == f'tech_map_{tech}']].iloc[:, 0] == 1
    ][['week_start', TARGET_COL]].sort_values('week_start').reset_index(drop=True)
 
    if grp.empty:
        print(f"Skipping forecast for {tech}: no rows found in weekly_segments.")
        continue
 
    history = grp.copy()
    preds_this_seg = []
 
    while True:
        last_date = history['week_start'].max()
        next_date = last_date + pd.Timedelta(weeks=1)
        if next_date > last_output_date:
            break
 
        temp_df = pd.concat(
            [history, pd.DataFrame({'week_start': [next_date], TARGET_COL: [np.nan]})],
            ignore_index=True,
        )
        featured_temp = build_features(temp_df, target_col=TARGET_COL, dropna=False)
        last_row = featured_temp.iloc[-1]
 
        bad_mask = last_row[FEATURES].isna() | np.isinf(last_row[FEATURES].astype(float))
        if bad_mask.any():
            bad = last_row[FEATURES][bad_mask].index.tolist()
            print(f"Warning: {tech} had NaN/inf for {bad} at {next_date.date()} -- filled with 0.")
            last_row[FEATURES] = last_row[FEATURES].where(~bad_mask, 0)
 
        X_next = pd.DataFrame([last_row[FEATURES].to_dict()])[FEATURES]
        if X_next.shape[0] != 1:
            raise ValueError(f"X_next has {X_next.shape[0]} rows, expected 1")
 
        raw_pred = np.asarray(model.predict(X_next)).ravel()
        pred = float(np.maximum(raw_pred[0], 0).round())
 
        history = pd.concat(
            [history, pd.DataFrame({'week_start': [next_date], TARGET_COL: [pred]})],
            ignore_index=True,
        )
 
        if next_date >= next_week_start:
            preds_this_seg.append((next_date, pred))
 
    row = {'technology': tech, 'specialisation': None}
    for date, pred in preds_this_seg:
        row[date.strftime('%Y-%m-%d')] = pred
    row['pxn_date'] = today.date()
    forecast_rows_ticket.append(row)
 
forecast_df_ticket = pd.DataFrame(forecast_rows_ticket)
week_cols_ticket = sorted(
    [c for c in forecast_df_ticket.columns if c not in ('technology', 'specialisation', 'pxn_date')]
)
forecast_df_ticket = forecast_df_ticket[
    ['technology', 'specialisation'] + week_cols_ticket + ['pxn_date']
]
 
output_filename_ticket = f"ticket_volume_forecast_13week_{today.strftime('%Y-%m-%d')}.csv"
forecast_df_ticket.to_csv(output_filename_ticket, index=False)
print(f"Saved: {output_filename_ticket}")
print(forecast_df_ticket)
