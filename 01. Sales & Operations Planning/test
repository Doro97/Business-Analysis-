import pandas as pd
import numpy as np
from sklearn.metrics import mean_absolute_error, mean_squared_error
from sklearn.linear_model import Ridge, Lasso
from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor
from sklearn.preprocessing import StandardScaler
from sklearn.pipeline import Pipeline

# =============================================================
# 1. WEEKLY SEGMENT AGGREGATION + ENCODING
# =============================================================
weekly_segments = (
    incident_res
    .groupby(['week_start', 'technology', 'specialisation'])
    .size()
    .reset_index(name='tickets')
    .sort_values(['technology', 'specialisation', 'week_start'])
    .reset_index(drop=True)
)

weekly_segments = pd.get_dummies(
    weekly_segments, columns=['technology', 'specialisation'], drop_first=False
)

tech_spec_cols = [
    c for c in weekly_segments.columns
    if c.startswith('technology_') or c.startswith('specialisation_')
]

# =============================================================
# 2. FEATURE ENGINEERING (reused identically for training AND forecasting)
# =============================================================
LEVEL_SHIFT_DATE = '2026-04-27'  # matches your original code

def build_segment_features(df, target_col='tickets', dropna=True):
    df = df.copy().sort_values('week_start').reset_index(drop=True)

    df['lag_1'] = df[target_col].shift(1)
    df['lag_2'] = df[target_col].shift(2)
    df['lag_4'] = df[target_col].shift(4)
    df['lag_13'] = df[target_col].shift(13)

    df['roll_4w'] = df[target_col].shift(1).rolling(4).mean()
    df['roll_8w'] = df[target_col].shift(1).rolling(8).mean()
    df['roll_13w'] = df[target_col].shift(1).rolling(13).mean()

    df['momentum'] = df['roll_4w'] - df['roll_8w']
    df['rolling_std_4w'] = df[target_col].shift(1).rolling(4).std()
    df['pct_change_1w'] = df[target_col].shift(1).pct_change(1)
    df['pct_change_4w'] = df[target_col].shift(1).pct_change(4)
    df['acceleration'] = df['pct_change_1w'] - df['pct_change_4w'].shift(1)

    df['week_of_year'] = pd.to_datetime(df['week_start']).dt.strftime('%W').astype(int)
    df['month'] = pd.to_datetime(df['week_start']).dt.month
    df['trend'] = np.arange(len(df))

    df['sin_52'] = np.sin(2 * np.pi * df['week_of_year'] / 52)
    df['cos_52'] = np.cos(2 * np.pi * df['week_of_year'] / 52)

    df['level_shift'] = (pd.to_datetime(df['week_start']) >= LEVEL_SHIFT_DATE).astype(int)

    return df.dropna() if dropna else df

segment_dfs = []
for _, grp in weekly_segments.groupby(tech_spec_cols, as_index=False):
    featured = build_segment_features(grp)
    if len(featured) > 5:
        segment_dfs.append(featured)

all_segments = pd.concat(segment_dfs).reset_index(drop=True)

# =============================================================
# 3. TRAIN/TEST SPLIT + MODEL SELECTION
# =============================================================
exclude = ['week_start', 'tickets']
SEGMENT_FEATURES = [c for c in all_segments.columns if c not in exclude]

X = all_segments[SEGMENT_FEATURES]
y = all_segments['tickets']

cutoff = all_segments['week_start'].max() - pd.Timedelta(weeks=13)
X_train = X[all_segments['week_start'] <= cutoff]
X_test = X[all_segments['week_start'] > cutoff]
y_train = y[all_segments['week_start'] <= cutoff]
y_test = y[all_segments['week_start'] > cutoff]

models = {
    'Ridge': Pipeline([('scaler', StandardScaler()), ('model', Ridge(alpha=1.0))]),
    'Lasso': Pipeline([('scaler', StandardScaler()), ('model', Lasso(alpha=0.1))]),
    'RandomForest': RandomForestRegressor(n_estimators=100, max_depth=4, random_state=42),
    'GradientBoosting': GradientBoostingRegressor(
        n_estimators=100, learning_rate=0.05, max_depth=3, random_state=42
    ),
}

results = []
fitted_models = {}
for name, model in models.items():
    model.fit(X_train, y_train)
    fitted_models[name] = model
    preds = np.asarray(np.maximum(model.predict(X_test), 0).round()).ravel()
    results.append({
        'Model': name,
        'MAE': round(mean_absolute_error(y_test, preds), 1),
        'RMSE': round(np.sqrt(mean_squared_error(y_test, preds)), 1),
    })

results_df = pd.DataFrame(results).sort_values('RMSE')
print(results_df.to_string(index=False))

# =============================================================
# 4. FIT BEST MODEL ON ALL DATA (Ridge, per your notebook)
# =============================================================
best_model = fitted_models['Ridge']
best_model.fit(X, y)  # refit on full history before forecasting forward

tech_cols = [c for c in all_segments.columns if c.startswith('technology_')]
spec_cols = [c for c in all_segments.columns if c.startswith('specialisation_')]

# =============================================================
# 5. BACKTEST SANITY CHECK (optional, matches your screenshots)
# =============================================================
test_data = all_segments[all_segments['week_start'] > cutoff].copy()
test_data['predicted'] = np.asarray(
    np.maximum(fitted_models['Ridge'].predict(X_test), 0).round()
).ravel()

test_data['technology'] = (
    test_data[tech_cols].idxmax(axis=1).str.replace('technology_', '', regex=False)
)
test_data['specialisation'] = (
    test_data[spec_cols].idxmax(axis=1).str.replace('specialisation_', '', regex=False)
)

# =============================================================
# 6. 13-WEEK FORWARD FORECAST (recursive, anchored to next week from today)
# =============================================================
N_WEEKS_AHEAD = 13
TARGET_COL = 'tickets'
today = pd.Timestamp.today().normalize()

this_week_start = today.to_period('W').start_time
next_week_start = this_week_start + pd.Timedelta(weeks=1)

forecast_rows_inc = []

for seg_key, grp in weekly_segments.groupby(tech_spec_cols, as_index=False):
    grp = grp.sort_values('week_start').reset_index(drop=True)

    # Needs enough history for lag_13 / roll_13w to be non-NaN from the first
    # forecasted step onward (matches the >5-row filter used at training, but
    # lag_13/roll_13w require substantially more history than that to be valid).
    if len(grp) < 14:
        continue

    seg_dummy_values = grp.iloc[-1][tech_spec_cols]
    history = grp[['week_start', TARGET_COL]].copy()
    preds_this_seg = []

    last_output_date = next_week_start + pd.Timedelta(weeks=N_WEEKS_AHEAD - 1)

    while True:
        last_date = history['week_start'].max()
        next_date = last_date + pd.Timedelta(weeks=1)
        if next_date > last_output_date:
            break

        # Extend history with a placeholder row and recompute features using the
        # SAME function used at training time -- this guarantees the forecast
        # features are derived identically to how the model was trained.
        temp_df = pd.concat(
            [history, pd.DataFrame({'week_start': [next_date], TARGET_COL: [np.nan]})],
            ignore_index=True,
        )
        featured_temp = build_segment_features(temp_df, target_col=TARGET_COL, dropna=False)
        last_row = featured_temp.iloc[-1]

        engineered_cols = [c for c in SEGMENT_FEATURES if c not in tech_spec_cols]
        if last_row[engineered_cols].isna().any():
            missing = last_row[engineered_cols][last_row[engineered_cols].isna()].index.tolist()
            raise ValueError(
                f"Segment {dict(seg_dummy_values)} has insufficient history to compute "
                f"{missing} for {next_date.date()}. Needs more historical weeks."
            )

        feat_row = {c: last_row[c] for c in engineered_cols}
        for c in tech_spec_cols:
            feat_row[c] = seg_dummy_values[c]

        X_next = pd.DataFrame([feat_row])[SEGMENT_FEATURES]
        if X_next.shape[0] != 1:
            raise ValueError(f"X_next has {X_next.shape[0]} rows, expected 1")

        raw_pred = np.asarray(best_model.predict(X_next)).ravel()
        pred = float(np.maximum(raw_pred[0], 0).round())

        history = pd.concat(
            [history, pd.DataFrame({'week_start': [next_date], TARGET_COL: [pred]})],
            ignore_index=True,
        )

        if next_date >= next_week_start:
            preds_this_seg.append((next_date, pred))

    technology = None
    specialisation = None
    for c in tech_cols:
        if seg_dummy_values[c] == 1:
            technology = c.replace('technology_', '')
    for c in spec_cols:
        if seg_dummy_values[c] == 1:
            specialisation = c.replace('specialisation_', '')

    row = {'technology': technology, 'specialisation': specialisation}
    for date, pred in preds_this_seg:
        row[date.strftime('%Y-%m-%d')] = pred
    row['pxn_date'] = today.date()
    forecast_rows_inc.append(row)

forecast_df_inc = pd.DataFrame(forecast_rows_inc)
week_cols_inc = sorted(
    [c for c in forecast_df_inc.columns if c not in ('technology', 'specialisation', 'pxn_date')]
)
forecast_df_inc = forecast_df_inc[['technology', 'specialisation'] + week_cols_inc + ['pxn_date']]

output_filename_inc = f"incidents_forecast_13week_{today.strftime('%Y-%m-%d')}.csv"
forecast_df_inc.to_csv(output_filename_inc, index=False)
print(f"Saved: {output_filename_inc}")
print(forecast_df_inc)
