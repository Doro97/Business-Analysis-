for (tech, spec), seg_info in segment_best_models_sr.items():
    try:
        feature_names = seg_info['X_train'].columns.tolist()
        model_name = seg_info['model_name']
        model = seg_info['model']

        # For Pipeline models, use the full pipeline predict
        # Pass DataFrame to maintain feature names
        explainer = shap.Explainer(
            model.predict,
            seg_info['X_train'],
            algorithm='permutation',
            feature_names=feature_names
        )
        shap_values = explainer(seg_info['X_test'])

        plt.figure(figsize=(10, 4))
        shap.summary_plot(shap_values, seg_info['X_test'],
                          feature_names=feature_names,
                          plot_type='bar', show=False)
        plt.title(f'SHAP — {tech} | {spec} (Best: {model_name}, MAE: {seg_info["MAE"]})')
        plt.tight_layout()
        plt.show()

    except Exception as e:
        print(f"SHAP failed for {tech} | {spec}: {e}")
