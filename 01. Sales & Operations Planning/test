MIN_ROWS = 15

segment_best_models = {}

for tech in all_segments['tech_map'].unique():
    seg = all_segments[all_segments['tech_map'] == tech].sort_values('week_start').reset_index(drop=True)

    if len(seg) < MIN_ROWS:
        print(f"Skipping {tech} — only {len(seg)} rows")
        continue

    X_seg = seg[FEATURES]
    y_seg = seg['ticket_count']

    X_train = X_seg[seg['week_start'] <= cutoff]
    X_test  = X_seg[seg['week_start'] > cutoff]
    y_train = y_seg[seg['week_start'] <= cutoff]
    y_test  = y_seg[seg['week_start'] > cutoff]

    if len(X_test) < 2 or len(X_train) < 5:
        print(f"Skipping {tech} — insufficient train/test rows ({len(X_train)}/{len(X_test)})")
        continue

    best_mae, best_name, best_model_obj, best_preds = np.inf, None, None, None
    for name, model in models.items():
        try:
            model.fit(X_train, y_train)
            preds = np.maximum(model.predict(X_test), 0).round()
            mae = mean_absolute_error(y_test, preds)
            if mae < best_mae:
                best_mae, best_name, best_model_obj, best_preds = mae, name, model, preds
        except Exception as e:
            print(f"{tech} | {name} failed: {e}")

    if best_model_obj:
        segment_best_models[tech] = {
            'model': best_model_obj,
            'model_name': best_name,
            'X_train': X_train, 'y_train': y_train,
            'X_test': X_test, 'y_test': y_test,
            'preds': best_preds,
            'week_start_test': seg.loc[X_test.index, 'week_start'].values,
            'MAE': round(best_mae, 2),
        }

summary = pd.DataFrame([
    {'technology': tech, 'best_model': v['model_name'], 'MAE': v['MAE'],
     'avg_actual': round(v['y_test'].mean(), 1)}
    for tech, v in segment_best_models.items()
]).sort_values('MAE', ascending=False)

print(summary.to_string(index=False))
