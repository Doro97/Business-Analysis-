# Week-start convention matching time_card's week_start (Monday-start)
incidents_joined["week_start"] = (
    incidents_joined["opened"] - pd.to_timedelta(incidents_joined["opened"].dt.weekday, unit="D")
).dt.normalize()

weekly_total = (
    incidents_joined
    .groupby("week_start")
    .size()
    .rename("ticket_count")
    .reset_index()
    .sort_values("week_start")
)

print(weekly_total.tail(15))


weekly_by_tech = (
    incidents_joined
    .groupby(["week_start", "technology"])
    .size()
    .rename("ticket_count")
    .reset_index()
)

# pivot for a readable view
tech_pivot = weekly_by_tech.pivot(index="week_start", columns="technology", values="ticket_count").fillna(0)
print(tech_pivot.tail(10))

weekly_by_spec = (
    incidents_joined
    .groupby(["week_start", "specialisation"])
    .size()
    .rename("ticket_count")
    .reset_index()
)

spec_pivot = weekly_by_spec.pivot(index="week_start", columns="specialisation", values="ticket_count").fillna(0)
print(spec_pivot.tail(10))



# 1. How many weeks of history do we actually have?
print(f"Weeks of history: {weekly_total.shape[0]}")
print(f"Date range: {weekly_total['week_start'].min()} to {weekly_total['week_start'].max()}")

# 2. Any gaps (weeks with zero tickets that might actually be missing data
#    rather than a genuine quiet week)?
full_range = pd.date_range(weekly_total["week_start"].min(), weekly_total["week_start"].max(), freq="W-MON")
missing_weeks = set(full_range) - set(weekly_total["week_start"])
print(f"Missing weeks: {sorted(missing_weeks)}")

# 3. Does the total reconcile? sum of tech_pivot rows should equal weekly_total
recon_check = tech_pivot.sum(axis=1) - weekly_total.set_index("week_start")["ticket_count"]
print("Max reconciliation diff:", recon_check.abs().max())
