import numpy as np
import pandas as pd
from sklearn.linear_model import Ridge, Lasso
from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import mean_absolute_error

# ------------------------------------------------------------------
# 0. Rebuild the cleaned weekly series (Step 3 + Step 4 cleaning)
# ------------------------------------------------------------------
ts = weekly_total.set_index("week_start")["ticket_count"].asfreq("W-MON")
ts = ts.rename_axis(None)  # index has NO name from here on

anomaly_mask = (ts.index >= "2026-04-20") & (ts.index <= "2026-05-18")
rolling_median_clean = ts.rolling(8, center=True, min_periods=4).median()
ts_cleaned = ts.astype(float).copy()
ts_cleaned[anomaly_mask] = rolling_median_clean[anomaly_mask]

dates = ts_cleaned.index.to_numpy()

def mape(actual, pred):
    return np.mean(np.abs((actual - pred) / actual)) * 100

# ------------------------------------------------------------------
# 1. Base self-referential features
# ------------------------------------------------------------------
base_df = pd.DataFrame({"y": ts_cleaned.to_numpy()})
base_df["lag_1"] = base_df["y"].shift(1)
base_df["lag_2"] = base_df["y"].shift(2)
base_df["lag_3"] = base_df["y"].shift(3)
base_df["lag_4"] = base_df["y"].shift(4)
base_df["rolling_mean_4"] = base_df["y"].shift(1).rolling(4).mean()
base_df["rolling_std_4"] = base_df["y"].shift(1).rolling(4).std()
base_df["trend_idx"] = np.arange(len(base_df))

# ------------------------------------------------------------------
# 2. Time_card-derived weekly features: headcount, hours, absence
# ------------------------------------------------------------------
tc = time_card.copy().reset_index(drop=True)
tc["week_start"] = (tc["date"] - pd.to_timedelta(tc["date"].dt.weekday, unit="D")).dt.normalize()

weekly_tc = (
    tc.groupby("week_start", as_index=False)
    .agg(
        active_headcount=("user_id", "nunique"),
        total_hours=("time_worked", "sum"),
    )
)

tc["is_leave_row"] = tc["category"] == "Sick/Holiday"
weekly_leave = (
    tc[tc["is_leave_row"]]
    .groupby("week_start", as_index=False)
    .agg(
        absence_hours=("time_worked", "sum"),
        people_on_leave=("user_id", "nunique"),
    )
)

weekly_tc = weekly_tc.merge(weekly_leave, on="week_start", how="left")
weekly_tc["absence_hours"] = weekly_tc["absence_hours"].fillna(0)
weekly_tc["people_on_leave"] = weekly_tc["people_on_leave"].fillna(0)
weekly_tc["absence_rate"] = weekly_tc["absence_hours"] / weekly_tc["total_hours"]

absence_threshold = weekly_tc["absence_rate"].quantile(0.75)
weekly_tc["is_sick_holiday"] = (weekly_tc["absence_rate"] > absence_threshold).astype(int)

# ------------------------------------------------------------------
# 3. is_spike / is_dip — BACKWARD-LOOKING ONLY (no lookahead leakage)
# ------------------------------------------------------------------
trailing_median = ts_cleaned.shift(1).rolling(8, min_periods=4).median()
trailing_mad = (
    (ts_cleaned.shift(1) - trailing_median).abs().rolling(8, min_periods=4).median()
)
deviation = (ts_cleaned - trailing_median) / trailing_mad.replace(0, np.nan)

spike_dip_df = pd.DataFrame({
    "week_start": dates,
    "is_spike": (deviation > 2).astype(int).fillna(0).to_numpy(),
    "is_dip": (deviation < -2).astype(int).fillna(0).to_numpy(),
})

# ------------------------------------------------------------------
# 4. Merge everything onto base_df, aligned by week position
# ------------------------------------------------------------------
feature_dates = pd.DataFrame({"week_start": dates})

merged = feature_dates.merge(weekly_tc, on="week_start", how="left")
merged = merged.merge(spike_dip_df, on="week_start", how="left")

fill_cols = [
    "active_headcount", "total_hours", "absence_hours", "people_on_leave",
    "absence_rate", "is_sick_holiday", "is_spike", "is_dip",
]
merged[fill_cols] = merged[fill_cols].fillna(0)

base_df_extended = pd.concat(
    [base_df.reset_index(drop=True), merged[fill_cols].reset_index(drop=True)],
    axis=1,
)

print("Feature table shape:", base_df_extended.shape)
print(base_df_extended.tail(10))
print("\nFeature summary:")
print(base_df_extended[fill_cols].describe())

# ------------------------------------------------------------------
# 5. Single fixed-origin, 13-week-ahead honest backtest
# ------------------------------------------------------------------
FORECAST_HORIZON = 13
n = len(base_df_extended)
origin = n - FORECAST_HORIZON - 1

def build_horizon_dataset(df, horizon):
    d = df.copy()
    d["target"] = d["y"].shift(-horizon)
    d = d.dropna()
    feature_cols = [c for c in d.columns if c not in ("y", "target")]
    return d[feature_cols], d["target"]

def get_models():
    return {
        "Ridge": Pipeline([("scaler", StandardScaler()), ("model", Ridge(alpha=1.0))]),
        "Lasso": Pipeline([("scaler", StandardScaler()), ("model", Lasso(alpha=1.0))]),
        "RandomForest": RandomForestRegressor(n_estimators=200, max_depth=4, random_state=42),
        "GradientBoosting": GradientBoostingRegressor(
            n_estimators=100, learning_rate=0.05, max_depth=3, random_state=42
        ),
    }

origin_features = base_df_extended.iloc[[origin]]
actual_future = ts_cleaned.iloc[origin + 1: origin + 1 + FORECAST_HORIZON]

results = []
predictions = {}

for name in get_models():
    preds = []
    for h in range(1, FORECAST_HORIZON + 1):
        X_h, y_h = build_horizon_dataset(base_df_extended, h)
        valid_idx = X_h.index <= (origin - h)
        X_train, y_train = X_h[valid_idx], y_h[valid_idx]

        model = get_models()[name]
        model.fit(X_train, y_train)
        pred = model.predict(origin_features[X_train.columns])[0]
        preds.append(pred)

    predictions[name] = preds
    mae = mean_absolute_error(actual_future.to_numpy(), preds)
    mp = mape(actual_future.to_numpy(), np.array(preds))
    results.append({"model": name, "MAE": round(mae, 1), "MAPE": round(mp, 1)})

results_df = pd.DataFrame(results).sort_values("MAE")
print("\n=== Results ===")
print(results_df)
print("\nHolt's benchmark -> MAE: 10.1  MAPE: 12.1%")

comparison = pd.DataFrame(
    {"actual": actual_future.to_numpy(), **predictions},
    index=actual_future.index,
)
print("\nActual vs predicted (13-week horizon):")
print(comparison)
