best_model = models['Ridge']
best_model.fit(X_train, y_train)

# Get predictions for test set
test_data = all_segments[all_segments['week_start'] > cutoff].copy()
test_data['predicted'] = np.maximum(best_model.predict(X_test), 0).round()

# ADDED: train data (actuals only, no predictions needed for history)
train_data = all_segments[all_segments['week_start'] <= cutoff].copy()

# Get tech and spec columns
tech_cols = [c for c in all_segments.columns if c.startswith('tech_map_')]
spec_cols = [c for c in all_segments.columns if c.startswith('specialisation_')]

# Recover tech_map and specialisation labels for BOTH train and test
test_data['tech_map'] = test_data[tech_cols].idxmax(axis=1).str.replace('tech_map_', '')
train_data['tech_map'] = train_data[tech_cols].idxmax(axis=1).str.replace('tech_map_', '')
# test_data['specialisation'] = test_data[spec_cols].idxmax(axis=1).str.replace('specialisation_', '')
# train_data['specialisation'] = train_data[spec_cols].idxmax(axis=1).str.replace('specialisation_', '')

# Plot per segment
segments = test_data.groupby(['tech_map'])
n = len(segments)

fig, axes = plt.subplots(n + 1, 1, figsize=(14, 4 * (n + 1)))

# Overall actual vs predicted (train + test)
all_train_total = train_data.groupby('week_start').agg({'ticket_count': 'sum'}).reset_index()
all_test_total  = test_data.groupby('week_start').agg({'ticket_count': 'sum', 'predicted': 'sum'}).reset_index()

axes[0].plot(all_train_total['week_start'], all_train_total['ticket_count'],
             color='black', label='Actual (train)')
axes[0].plot(all_test_total['week_start'], all_test_total['ticket_count'],
             color='black', linestyle='--', marker='o', label='Actual (test)')
axes[0].plot(all_test_total['week_start'], all_test_total['predicted'],
             color='tab:blue', marker='s', label='Predicted')
axes[0].axvline(pd.to_datetime(cutoff), color='red', linestyle=':', alpha=0.6, label='Train/Test split')
axes[0].set_title('Ticket volume Actual vs Predicted (Total)')
axes[0].set_ylabel('Tickets')
axes[0].legend()
axes[0].tick_params(axis='x', rotation=45)

# Per segment — now shows train history leading into the test/predicted window
for ax, (tech, grp) in zip(axes[1:], segments):
    grp = grp.sort_values('week_start')
    train_grp = train_data[train_data['tech_map'] == tech].sort_values('week_start')

    ax.plot(train_grp['week_start'], train_grp['ticket_count'],
            color='black', label='Actual (train)')
    ax.plot(grp['week_start'], grp['ticket_count'],
            color='black', linestyle='--', marker='o', label='Actual (test)')
    ax.plot(grp['week_start'], grp['predicted'],
            color='tab:blue', marker='s', label='Predicted')
    ax.axvline(pd.to_datetime(cutoff), color='red', linestyle=':', alpha=0.6)
    ax.set_title(f'Ticket Volume for {tech}')
    ax.set_ylabel('Tickets')
    ax.legend()
    ax.tick_params(axis='x', rotation=45)

plt.tight_layout()
plt.show()
