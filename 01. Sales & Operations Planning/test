axes[1].plot(train_c.index, train_c.values, color="black", label="Train (actual)", linewidth=1.5)
axes[1].plot(test_c.index, test_c.values, color="black", linestyle="--", marker="o", label="Test (actual)")
axes[1].plot(test_c.index, pred_trend_c.values, color="tab:blue", marker="s",
             label=f"Holt's trend (MAE={mae_trend_c:.1f})")
