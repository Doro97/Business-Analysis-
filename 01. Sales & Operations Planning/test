import pandas as pd
import numpy as np

N_WEEKS_AHEAD = 13
TARGET_COL = "cr_count"

# Make sure the final model is fit on ALL available data (not just train split)
# so the forecast uses everything you have up to today.
best_cr_seg.fit(X_seg_cr, y_seg_cr)

forecast_rows = []
today = pd.Timestamp.today().normalize()

for seg_key, grp in cr_seg_encoded.groupby(seg_cols_cr, as_index=False):
    grp = grp.sort_values("week_start").reset_index(drop=True)

    if len(grp) < 5:
        # not enough history to build lag/rolling features safely
        continue

    # Pull the segment's dummy columns (constant per segment)
    seg_dummy_values = grp.iloc[-1][seg_cols_cr]

    # Rolling history buffer: keep week_start + target col
    history = grp[["week_start", TARGET_COL]].copy()

    preds_this_seg = []

    for step in range(1, N_WEEKS_AHEAD + 1):
        last_date = history["week_start"].max()
        next_date = last_date + pd.Timedelta(weeks=1)

        lag_1 = history[TARGET_COL].iloc[-1]
        roll_4w = history[TARGET_COL].iloc[-4:].mean()
        # momentum = roll_4w computed one step back minus target shifted 2
        # (mirrors: df['roll_4w'] - df[target].shift(2) in build_seg_features)
        if len(history) >= 5:
            prev_roll_4w = history[TARGET_COL].iloc[-5:-1].mean()
        else:
            prev_roll_4w = history[TARGET_COL].iloc[:-1].mean()
        shift_2 = history[TARGET_COL].iloc[-2] if len(history) >= 2 else lag_1
        momentum = roll_4w - shift_2
        month = next_date.month

        feat_row = {
            "lag_1": lag_1,
            "roll_4w": roll_4w,
            "momentum": momentum,
            "month": month,
        }
        # add this segment's dummy columns
        for c in seg_cols_cr:
            feat_row[c] = seg_dummy_values[c]

        X_next = pd.DataFrame([feat_row])[FEATURES_CR_SEG]  # enforce column order
        pred = float(np.maximum(best_cr_seg.predict(X_next), 0).round())

        preds_this_seg.append((next_date, pred))

        # append prediction to history so next iteration's lag/roll use it
        history = pd.concat(
            [history, pd.DataFrame({"week_start": [next_date], TARGET_COL: [pred]})],
            ignore_index=True,
        )

    # Recover human-readable technology / specialisation labels from dummies
    technology = None
    specialisation = None
    for c in tech_cols_cr:
        if seg_dummy_values[c] == 1:
            technology = c.replace("technology_", "")
    for c in spec_cols_cr:
        if seg_dummy_values[c] == 1:
            specialisation = c.replace("specialisation_", "")

    row = {"technology": technology, "specialisation": specialisation}
    for i, (_, pred) in enumerate(preds_this_seg, start=1):
        row[f"week_{i}"] = pred
    row["pxn_date"] = today.date()

    forecast_rows.append(row)

forecast_df = pd.DataFrame(forecast_rows)

# reorder columns: technology, specialisation, week_1..week_13, pxn_date
week_cols = [f"week_{i}" for i in range(1, N_WEEKS_AHEAD + 1)]
forecast_df = forecast_df[["technology", "specialisation"] + week_cols + ["pxn_date"]]

forecast_df.to_csv("forecast_13week.csv", index=False)
