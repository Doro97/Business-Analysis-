import pandas as pd
import numpy as np
from sklearn.metrics import mean_absolute_error, mean_squared_error

# =============================================================
# 1. SEGMENT BREAKDOWN + ENRICHMENT
# =============================================================
cr_tech = (
    time_card[time_card['task'].isin(cr['number'])]
    .groupby(['task', 'technology', 'specialisation'])['time_worked']
    .sum()
    .reset_index()
    .sort_values('time_worked', ascending=False)
    .drop_duplicates(subset='task', keep='first')
    .rename(columns={'task': 'number'})
)[['number', 'technology', 'specialisation']]

cr_enriched = cr.merge(cr_tech, on='number', how='left')

# =============================================================
# 2. WEEKLY AGGREGATION + ENCODING
# =============================================================
weekly_cr_seg = (
    cr_enriched[cr_enriched['technology'].notna()]
    .groupby(['week_start', 'technology', 'specialisation'])
    .size()
    .reset_index(name='cr_count')
    .sort_values(['technology', 'specialisation', 'week_start'])
    .reset_index(drop=True)
)

cr_seg_encoded = pd.get_dummies(
    weekly_cr_seg, columns=['technology', 'specialisation'], drop_first=False
)

seg_cols_cr = [
    c for c in cr_seg_encoded.columns
    if c.startswith('technology_') or c.startswith('specialisation_')
]

# =============================================================
# 3. FEATURE ENGINEERING PER SEGMENT
# =============================================================
def build_seg_features(df, target_col):
    df = df.copy().sort_values('week_start').reset_index(drop=True)
    df['lag_1'] = df[target_col].shift(1)
    df['roll_4w'] = df[target_col].shift(1).rolling(4).mean()
    df['momentum'] = df['roll_4w'] - df[target_col].shift(2)
    df['month'] = pd.to_datetime(df['week_start']).dt.month
    return df.dropna()

seg_dfs_cr = []
for _, grp in cr_seg_encoded.groupby(seg_cols_cr, as_index=False):
    featured = build_seg_features(grp, 'cr_count')
    if len(featured) > 5:
        seg_dfs_cr.append(featured)

all_seg_cr = pd.concat(seg_dfs_cr).reset_index(drop=True)

# =============================================================
# 4. TRAIN/TEST SPLIT + MODEL SELECTION
# =============================================================
FEATURES_CR_SEG = [c for c in all_seg_cr.columns if c not in ['cr_count', 'week_start']]
X_seg_cr = all_seg_cr[FEATURES_CR_SEG]
y_seg_cr = all_seg_cr['cr_count']

cutoff_cr_seg = all_seg_cr['week_start'].max() - pd.Timedelta(weeks=13)
train_m_cr = all_seg_cr['week_start'] <= cutoff_cr_seg
test_m_cr = all_seg_cr['week_start'] > cutoff_cr_seg

X_train_seg_cr, X_test_seg_cr = X_seg_cr[train_m_cr], X_seg_cr[test_m_cr]
y_train_seg_cr, y_test_seg_cr = y_seg_cr[train_m_cr], y_seg_cr[test_m_cr]

results_seg_cr = []
fitted_seg_cr = {}
for name, model in models.items():
    model.fit(X_train_seg_cr, y_train_seg_cr)
    fitted_seg_cr[name] = model
    preds = np.asarray(np.maximum(model.predict(X_test_seg_cr), 0).round()).ravel()
    results_seg_cr.append({
        'Model': name,
        'MAE': round(mean_absolute_error(y_test_seg_cr, preds), 1),
        'RMSE': round(np.sqrt(mean_squared_error(y_test_seg_cr, preds)), 1),
        'Bias': round(np.mean(preds - y_test_seg_cr.values), 1),
    })

print(pd.DataFrame(results_seg_cr).sort_values('MAE'))

# =============================================================
# 5. FIT BEST MODEL (Ridge, per your backtest) ON ALL DATA
# =============================================================
best_cr_seg = fitted_seg_cr['Ridge']
best_cr_seg.fit(X_seg_cr, y_seg_cr)  # refit on full history before forecasting forward

tech_cols_cr = [c for c in all_seg_cr.columns if c.startswith('technology_')]
spec_cols_cr = [c for c in all_seg_cr.columns if c.startswith('specialisation_')]

# =============================================================
# 6. BACKTEST SANITY CHECK (optional, matches your screenshots)
# =============================================================
best_check = fitted_seg_cr['Ridge']
test_seg_cr = all_seg_cr[test_m_cr].copy()
test_seg_cr['predicted'] = np.asarray(
    np.maximum(best_check.predict(X_test_seg_cr), 0).round()
).ravel()

test_seg_cr['technology'] = (
    test_seg_cr[tech_cols_cr].idxmax(axis=1).str.replace('technology_', '', regex=False)
)
test_seg_cr['specialisation'] = (
    test_seg_cr[spec_cols_cr].idxmax(axis=1).str.replace('specialisation_', '', regex=False)
)

segment_metrics_cr = (
    test_seg_cr.groupby(['technology', 'specialisation'])[['cr_count', 'predicted']]
    .apply(lambda g: pd.Series({'MAE': mean_absolute_error(g['cr_count'], g['predicted'])}))
    .reset_index()
    .sort_values('MAE', ascending=False)
)
segment_metrics_cr['MAE'] = segment_metrics_cr['MAE'].round(2)
segment_metrics_cr = segment_metrics_cr.reset_index(drop=True)
print(segment_metrics_cr)

# =============================================================
# 7. 13-WEEK FORWARD FORECAST (recursive, per segment)
# =============================================================
N_WEEKS_AHEAD = 13
TARGET_COL = 'cr_count'
today = pd.Timestamp.today().normalize()

forecast_rows = []

for seg_key, grp in cr_seg_encoded.groupby(seg_cols_cr, as_index=False):
    grp = grp.sort_values('week_start').reset_index(drop=True)
    if len(grp) < 5:
        continue  # not enough history for lag/rolling features

    seg_dummy_values = grp.iloc[-1][seg_cols_cr]
    history = grp[['week_start', TARGET_COL]].copy()
    preds_this_seg = []

    for step in range(1, N_WEEKS_AHEAD + 1):
        last_date = history['week_start'].max()
        next_date = last_date + pd.Timedelta(weeks=1)

        lag_1 = history[TARGET_COL].iloc[-1]
        roll_4w = history[TARGET_COL].iloc[-4:].mean()
        prev_roll_4w = (
            history[TARGET_COL].iloc[-5:-1].mean()
            if len(history) >= 5
            else history[TARGET_COL].iloc[:-1].mean()
        )
        shift_2 = history[TARGET_COL].iloc[-2] if len(history) >= 2 else lag_1
        momentum = roll_4w - shift_2
        month = next_date.month

        feat_row = {'lag_1': lag_1, 'roll_4w': roll_4w, 'momentum': momentum, 'month': month}
        for c in seg_cols_cr:
            feat_row[c] = seg_dummy_values[c]

        X_next = pd.DataFrame([feat_row])[FEATURES_CR_SEG]
        if X_next.shape[0] != 1:
            raise ValueError(f"X_next has {X_next.shape[0]} rows, expected 1")

        raw_pred = np.asarray(best_cr_seg.predict(X_next)).ravel()
        pred = float(np.maximum(raw_pred[0], 0).round())

        preds_this_seg.append((next_date, pred))
        history = pd.concat(
            [history, pd.DataFrame({'week_start': [next_date], TARGET_COL: [pred]})],
            ignore_index=True,
        )

    technology = None
    specialisation = None
    for c in tech_cols_cr:
        if seg_dummy_values[c] == 1:
            technology = c.replace('technology_', '')
    for c in spec_cols_cr:
        if seg_dummy_values[c] == 1:
            specialisation = c.replace('specialisation_', '')

    row = {'technology': technology, 'specialisation': specialisation}
    for date, pred in preds_this_seg:
        row[date.strftime('%Y-%m-%d')] = pred
    row['pxn_date'] = today.date()
    forecast_rows.append(row)

forecast_df = pd.DataFrame(forecast_rows)
# week columns are the actual forecasted week_start dates, in chronological order
week_cols = sorted(
    [c for c in forecast_df.columns if c not in ('technology', 'specialisation', 'pxn_date')]
)
forecast_df = forecast_df[['technology', 'specialisation'] + week_cols + ['pxn_date']]

forecast_df.to_csv('cr_forecast_13week.csv', index=False)
print(forecast_df)
