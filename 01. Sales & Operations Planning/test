import re
from rapidfuzz import fuzz
from collections import Counter, defaultdict

def normalize_name(name):
    if not isinstance(name, str):
        return ""
    cleaned = re.sub(r"[,]", " ", name).strip().lower()
    cleaned = re.sub(r"\s+", " ", cleaned)
    return " ".join(sorted(cleaned.split(" ")))

def pick_matched_name(raw_names, threshold=85):
    raw_names = [n.strip() for n in raw_names if isinstance(n, str) and n.strip()]
    if not raw_names:
        return ""
    normalized_to_raws = defaultdict(list)
    for raw in raw_names:
        normalized_to_raws[normalize_name(raw)].append(raw)

    clusters = []
    for norm in normalized_to_raws:
        placed = False
        for cluster in clusters:
            if fuzz.token_sort_ratio(norm, cluster[0]) >= threshold:
                cluster.append(norm)
                placed = True
                break
        if not placed:
            clusters.append([norm])

    best_cluster = max(clusters, key=lambda c: sum(len(normalized_to_raws[n]) for n in c))
    candidates = [r for n in best_cluster for r in normalized_to_raws[n]]
    counts = Counter(candidates)
    top = max(counts.values())
    return max([n for n, c in counts.items() if c == top], key=len)


matched_name_by_uid = {}

for uid, group in raw.groupby("user_id"):
    matched_name_by_uid[uid] = pick_matched_name(group["name"].tolist())

