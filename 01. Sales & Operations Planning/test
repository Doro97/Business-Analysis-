"""
Incident Volume Forecast Pipeline (adapted from SR_Volume_Forecast.py)
=======================================================================
Same methodology as the SR pipeline: total model + per-segment
(technology x specialisation) models, lag/rolling/spike features,
recursive 13-week forecast.

Assumes already in memory:
    - weekly_total     : [week_start, ticket_count]   (Step 3)
    - incidents_joined : incidents + technology/specialisation (Step 2)
    - time_card        : raw time_card data

One addition vs. the SR script: anomaly cleaning for the known
April 20 - May 18 2026 bulk-creation spike in incidents (SR data may
not have this issue -- check before reusing this exact date range
on other datasets).
"""

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from datetime import datetime
from sklearn.linear_model import Ridge, Lasso, HuberRegressor
from sklearn.ensemble import GradientBoostingRegressor, RandomForestRegressor
from sklearn.metrics import mean_absolute_error, mean_squared_error, mean_absolute_percentage_error
from sklearn.preprocessing import StandardScaler
from sklearn.pipeline import Pipeline

# ============================================================
# CONFIG
# ============================================================
ANOMALY_START = '2026-04-20'
ANOMALY_END   = '2026-05-18'
TEST_WEEKS    = 13
MIN_ROWS      = 5
FEATURES      = ['lag_1', 'lag_2', 'month', 'rolling_4w',
                  'above_avg', 'is_spike', 'is_dip']

# ============================================================
# MODELS
# ============================================================
def get_models():
    return {
        'Ridge':            Pipeline([('scaler', StandardScaler()), ('model', Ridge(alpha=1.0))]),
        'Lasso':            Pipeline([('scaler', StandardScaler()), ('model', Lasso(alpha=0.1))]),
        'Huber':            Pipeline([('scaler', StandardScaler()), ('model', HuberRegressor())]),
        'RandomForest':     RandomForestRegressor(n_estimators=100, max_depth=4, random_state=42),
        'GradientBoosting': GradientBoostingRegressor(n_estimators=100, learning_rate=0.05,
                                                       max_depth=3, random_state=42)
    }

# ============================================================
# ANOMALY CLEANING (new vs SR script -- incidents-specific)
# ============================================================
def clean_anomaly(weekly_df, count_col, start=ANOMALY_START, end=ANOMALY_END, window=8):
    weekly_df = weekly_df.copy()
    ts = weekly_df.set_index('week_start')[count_col].astype(float)
    mask = (ts.index >= start) & (ts.index <= end)
    rolling_median = ts.rolling(window, center=True, min_periods=4).median()
    ts[mask] = rolling_median[mask]
    weekly_df[count_col] = ts.values
    return weekly_df

# ============================================================
# CONTEXT FEATURES (company/service breadth + sick/holiday)
# ============================================================
def build_context(incidents_joined, time_card):
    context = incidents_joined.groupby('week_start').agg(
        n_companies=('company', 'nunique'),
        n_services=('business_service', 'nunique')
    ).reset_index()

    sick = (
        time_card[time_card['category'] == 'Sick/Holiday']
        .groupby('week_start')['time_worked']
        .sum()
        .reset_index(name='sick_holiday_hours')
    )
    threshold = sick['sick_holiday_hours'].quantile(0.75)
    sick['is_sick_holiday'] = (sick['sick_holiday_hours'] > threshold).astype(int)

    return context, sick

# ============================================================
# FEATURE ENGINEERING (identical to SR script)
# ============================================================
def build_features(df, target_col='ticket_count'):
    df = df.copy().set_index('week_start')
    df.index = pd.to_datetime(df.index)

    df['lag_1']      = df[target_col].shift(1)
    df['lag_2']      = df[target_col].shift(2)
    df['month']      = df.index.month
    df['rolling_4w'] = df[target_col].shift(1).rolling(4).mean()
    df['above_avg']  = (df[target_col].shift(1) > df['rolling_4w']).astype(int)

    rolling_std  = df[target_col].shift(1).rolling(8).std()
    rolling_mean = df[target_col].shift(1).rolling(8).mean()
    df['is_spike'] = (df[target_col].shift(1) > rolling_mean + 1.5 * rolling_std).astype(int)
    df['is_dip']   = (df[target_col].shift(1) < rolling_mean - 1.5 * rolling_std).astype(int)

    df['n_services_lag1'] = df['n_services'].shift(1) if 'n_services' in df.columns else 0

    return df.dropna()

# ============================================================
# TOTAL VOLUME MODEL
# ============================================================
def train_total_model(weekly_total_clean):
    feature_df = build_features(weekly_total_clean)
    excluded   = ['ticket_count', 'n_companies', 'n_services']
    features   = [c for c in feature_df.columns if c not in excluded]

    X = feature_df[features]
    y = feature_df['ticket_count']
    X_train, X_test = X.iloc[:-TEST_WEEKS], X.iloc[-TEST_WEEKS:]
    y_train, y_test = y.iloc[:-TEST_WEEKS], y.iloc[-TEST_WEEKS:]

    models  = get_models()
    results = []
    fitted  = {}

    for name, model in models.items():
        model.fit(X_train, y_train)
        fitted[name] = model
        preds = np.maximum(model.predict(X_test), 0).round()
        results.append({
            'Model': name,
            'MAE':  round(mean_absolute_error(y_test, preds), 1),
            'MAPE': round(mean_absolute_percentage_error(y_test, preds) * 100, 1),
            'RMSE': round(np.sqrt(mean_squared_error(y_test, preds)), 1),
            'Bias': round(np.mean(preds - y_test.values), 1)
        })

    results_df = pd.DataFrame(results).sort_values('MAE')
    print("=== Total Incident Volume Model Comparison ===")
    print(results_df.to_string(index=False))

    best_name  = results_df.iloc[0]['Model']
    best_model = fitted[best_name]
    best_model.fit(X_train, y_train)
    print(f"\nBest model: {best_name}")

    return best_model, fitted, X_train, X_test, y_train, y_test, features

# ============================================================
# TECHNOLOGY/SPECIALISATION SEGMENT SERIES
# ============================================================
def build_weekly_segment(incidents_joined):
    seg = (
        incidents_joined[incidents_joined['technology'] != 'Unclassified']
        .groupby(['week_start', 'technology', 'specialisation'])
        .size()
        .reset_index(name='ticket_count')
        .sort_values(['technology', 'specialisation', 'week_start'])
        .reset_index(drop=True)
    )
    return seg

# ============================================================
# SEGMENT MODELS (identical logic to SR script)
# ============================================================
def train_segment_models(weekly_seg):
    segment_best_models = {}

    for (tech, spec), grp in weekly_seg.groupby(['technology', 'specialisation']):
        grp = grp.sort_values('week_start').reset_index(drop=True)

        # clean anomaly window per-segment too, so segment models aren't
        # distorted by the same bulk-creation artifact
        grp = clean_anomaly(grp, 'ticket_count')

        grp['lag_1']      = grp['ticket_count'].shift(1)
        grp['lag_2']      = grp['ticket_count'].shift(2)
        grp['month']      = pd.to_datetime(grp['week_start']).dt.month
        grp['rolling_4w'] = grp['ticket_count'].shift(1).rolling(4).mean()
        grp['above_avg']  = (grp['ticket_count'].shift(1) > grp['rolling_4w']).astype(int)
        rolling_std       = grp['ticket_count'].shift(1).rolling(8).std()
        rolling_mean      = grp['ticket_count'].shift(1).rolling(8).mean()
        grp['is_spike']   = (grp['ticket_count'].shift(1) > rolling_mean + 1.5 * rolling_std).astype(int)
        grp['is_dip']     = (grp['ticket_count'].shift(1) < rolling_mean - 1.5 * rolling_std).astype(int)
        grp = grp.dropna()

        if len(grp) < MIN_ROWS:
            print(f"Skipping {tech} | {spec} — only {len(grp)} usable rows")
            continue

        X = grp[FEATURES].astype(float)
        y = grp['ticket_count'].astype(float)

        test_size       = min(TEST_WEEKS, len(grp) // 3)
        if test_size < 2:
            print(f"Skipping {tech} | {spec} — test window too small ({test_size})")
            continue
        X_train, X_test = X.iloc[:-test_size], X.iloc[-test_size:]
        y_train, y_test = y.iloc[:-test_size], y.iloc[-test_size:]
        week_start_test = grp['week_start'].iloc[-test_size:].values

        if len(X_train) < 5:
            print(f"Skipping {tech} | {spec} — insufficient training rows")
            continue

        best_mae, best_name, best_preds, best_model_obj = np.inf, None, None, None
        models = get_models()

        for name, model in models.items():
            try:
                model.fit(X_train, y_train)
                preds = np.maximum(model.predict(X_test), 0).round()
                mae   = mean_absolute_error(y_test, preds)
                if mae < best_mae:
                    best_mae, best_name, best_preds, best_model_obj = mae, name, preds, model
            except Exception as e:
                print(f"{tech} | {spec} | {name} failed: {e}")

        if best_model_obj:
            segment_best_models[(tech, spec)] = {
                'model':           best_model_obj,
                'model_name':      best_name,
                'X_train':         X_train,
                'X_test':          X_test,
                'y_train':         y_train,
                'y_test':          y_test,
                'best_preds':      best_preds,
                'week_start_test': week_start_test,
                'MAE':             round(best_mae, 2),
                'Bias':            round(np.mean(best_preds - y_test.values), 2),
                'avg_actual':      round(y_test.mean(), 2)
            }

    summary = pd.DataFrame([
        {'technology': k[0], 'specialisation': k[1],
         'best_model': v['model_name'], 'MAE': v['MAE'],
         'avg_actual': v['avg_actual'], 'Bias': v['Bias']}
        for k, v in segment_best_models.items()
    ]).sort_values('MAE', ascending=False)

    print("\n=== Best Model Per Segment ===")
    print(summary.to_string(index=False))

    return segment_best_models

# ============================================================
# 13-WEEK FORECAST (recursive, same as SR script -- see caution below)
# ============================================================
def generate_forecast(segment_best_models, weekly_seg):
    last_date      = pd.to_datetime(weekly_seg['week_start'].max())
    forecast_dates = pd.date_range(start=last_date + pd.Timedelta(weeks=1), periods=13, freq='W-MON')
    pxn_date       = datetime.today().strftime('%Y-%m-%d')
    forecast_rows  = []

    for (tech, spec), seg_info in segment_best_models.items():
        model = seg_info['model']
        full_hist = weekly_seg[
            (weekly_seg['technology'] == tech) &
            (weekly_seg['specialisation'] == spec)
        ].sort_values('week_start')['ticket_count'].values.tolist()

        week_forecasts = []
        for date in forecast_dates:
            hist   = pd.Series(full_hist)
            roll_4 = hist.iloc[-4:].mean() if len(hist) >= 4 else hist.mean()
            roll_8 = hist.iloc[-8:].mean() if len(hist) >= 8 else hist.mean()
            std_8  = hist.iloc[-8:].std()  if len(hist) >= 8 else 0

            row = {
                'lag_1':      hist.iloc[-1],
                'lag_2':      hist.iloc[-2] if len(hist) >= 2 else hist.iloc[-1],
                'month':      date.month,
                'rolling_4w': roll_4,
                'above_avg':  int(hist.iloc[-1] > roll_4),
                'is_spike':   int(hist.iloc[-1] > roll_8 + 1.5 * std_8),
                'is_dip':     int(hist.iloc[-1] < roll_8 - 1.5 * std_8)
            }

            row_df = pd.DataFrame([row])[FEATURES].astype(float)
            pred   = max(0, round(model.predict(row_df)[0]))
            week_forecasts.append(pred)
            full_hist.append(pred)

        forecast_rows.append({
            'technology':     tech,
            'specialisation': spec,
            **{f'week_{i+1}': v for i, v in enumerate(week_forecasts)},
            'pxn_date':       pxn_date
        })

    return pd.DataFrame(forecast_rows).sort_values(['technology', 'specialisation']).reset_index(drop=True)

# ============================================================
# MAIN
# ============================================================
if __name__ == '__main__':
    # weekly_total, incidents_joined, time_card assumed already in memory

    # 1. Clean anomaly on total series
    weekly_total_clean = clean_anomaly(weekly_total, 'ticket_count')

    # 2. Context features (company/service breadth, sick/holiday)
    context, sick = build_context(incidents_joined, time_card)
    weekly_total_clean = weekly_total_clean.merge(context, on='week_start', how='left')

    # 3. Segment series (technology x specialisation)
    weekly_seg = build_weekly_segment(incidents_joined)

    # 4. Train total model
    best_model, fitted, X_train, X_test, y_train, y_test, features = train_total_model(weekly_total_clean)

    # 5. Train segment models
    segment_best_models = train_segment_models(weekly_seg)

    # 6. Forecast
    forecast_df = generate_forecast(segment_best_models, weekly_seg)
    print("\n=== 13-Week Forecast ===")
    print(forecast_df.to_string(index=False))

    forecast_df.to_csv('incident_volume_forecast_by_segment.csv', index=False)
    print("\nSaved: incident_volume_forecast_by_segment.csv")
