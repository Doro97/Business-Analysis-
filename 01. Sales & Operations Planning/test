def mape(actual, pred):
    return np.mean(np.abs((actual - pred) / actual)) * 100

FORECAST_HORIZON = 13

# ------------------------------------------------------------------
# 1. Base self-features (reset index to simple integer position so
#    horizon shifting/alignment is unambiguous)
# ------------------------------------------------------------------
def build_base_features(ts):
    df = pd.DataFrame({"y": ts.values}, index=range(len(ts)))
    df["lag_1"] = df["y"].shift(1)
    df["lag_2"] = df["y"].shift(2)
    df["lag_3"] = df["y"].shift(3)
    df["lag_4"] = df["y"].shift(4)
    df["rolling_mean_4"] = df["y"].shift(1).rolling(4).mean()
    df["rolling_std_4"] = df["y"].shift(1).rolling(4).std()
    df["trend_idx"] = np.arange(len(df))
    return df

base_df = build_base_features(ts_cleaned)
dates = ts_cleaned.index  # integer position i <-> dates[i]

def build_horizon_dataset(base_df, horizon):
    d = base_df.copy()
    d["target"] = d["y"].shift(-horizon)
    d = d.dropna()
    feature_cols = [c for c in d.columns if c not in ("y", "target")]
    return d[feature_cols], d["target"]

def get_models():
    return {
        "Ridge": Pipeline([("scaler", StandardScaler()), ("model", Ridge(alpha=1.0))]),
        "Lasso": Pipeline([("scaler", StandardScaler()), ("model", Lasso(alpha=1.0))]),
        "RandomForest": RandomForestRegressor(n_estimators=200, max_depth=4, random_state=42),
        "GradientBoosting": GradientBoostingRegressor(n_estimators=100, learning_rate=0.05, max_depth=3, random_state=42),
    }

# ------------------------------------------------------------------
# 2. Rolling-origin backtest: test at several fixed cutoffs, each time
#    forecasting all 13 horizons ahead from that origin, using only
#    data strictly before the origin to train.
# ------------------------------------------------------------------
n = len(base_df)
# space origins ~4 weeks apart, leaving room for a full 13-week forecast after each
origins = [o for o in range(n - FORECAST_HORIZON - 1, n - FORECAST_HORIZON - 17, -4) if o > 20]
origins = sorted(origins)
print(f"Testing {len(origins)} origins: {[dates[o].date() for o in origins]}")

all_errors = {name: [] for name in get_models()}

for origin in origins:
    origin_features = base_df.iloc[[origin]]
    actual_future = ts_cleaned.iloc[origin + 1: origin + 1 + FORECAST_HORIZON]
    if len(actual_future) < FORECAST_HORIZON:
        continue

    for name in get_models():
        preds = []
        for h in range(1, FORECAST_HORIZON + 1):
            X_h, y_h = build_horizon_dataset(base_df, h)
            X_train = X_h[X_h.index <= origin]
            y_train = y_h[y_h.index <= origin]

            model = get_models()[name]
            model.fit(X_train, y_train)
            pred = model.predict(origin_features[X_train.columns])[0]
            preds.append(pred)

        mae = mean_absolute_error(actual_future.values, preds)
        all_errors[name].append(mae)

# ------------------------------------------------------------------
# 3. Aggregate across origins
# ------------------------------------------------------------------
summary = pd.DataFrame({
    "model": list(all_errors.keys()),
    "mean_MAE": [np.mean(v) for v in all_errors.values()],
    "std_MAE": [np.std(v) for v in all_errors.values()],
    "n_origins": [len(v) for v in all_errors.values()],
}).sort_values("mean_MAE")

print(summary)
print(f"\nHolt's benchmark -> MAE: 10.1  MAPE: 12.1%")
