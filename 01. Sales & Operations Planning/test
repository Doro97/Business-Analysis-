# ------------------------------------------------------------------
# 1. Last 13 actual weeks, per technology
# ------------------------------------------------------------------
last_actual_date = pd.to_datetime(inc_by_tech['week_start'].max())
first_actual_date = last_actual_date - pd.Timedelta(weeks=12)  # 13 weeks inclusive

actual_recent = inc_by_tech[
    (pd.to_datetime(inc_by_tech['week_start']) >= first_actual_date) &
    (pd.to_datetime(inc_by_tech['week_start']) <= last_actual_date)
].copy()
actual_recent['week_start'] = pd.to_datetime(actual_recent['week_start'])

actual_pivot = actual_recent.pivot(index='technology', columns='week_start', values='ticket_count')
actual_pivot.columns = [c.strftime('%Y-%m-%d') for c in actual_pivot.columns]

# ------------------------------------------------------------------
# 2. Next 4 predicted weeks, per technology
# ------------------------------------------------------------------
week_cols = [c for c in forecast_df_inc.columns if c not in ('technology', 'pxn_date')]
next_4_cols = sorted(week_cols, key=lambda c: pd.to_datetime(c))[:4]

predicted_pivot = forecast_df_inc.set_index('technology')[next_4_cols]

# ------------------------------------------------------------------
# 3. Combine side by side: actuals | predicted
# ------------------------------------------------------------------
combined_pivot = actual_pivot.join(predicted_pivot, how='outer')

print(combined_pivot)
